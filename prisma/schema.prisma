generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Certificate {
  id       String   @id @default(uuid())
  email    String
  name     String
  course   String
  template String
  isSent   Boolean  @default(false)
  issuedAt DateTime @default(now())
}
